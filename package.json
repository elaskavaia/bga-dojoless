{
  "name": "bga.dojoless",
  "version": "1.0.0",
  "description": "",
  "main": "modules/js/Game.js",
  "scripts": {
    "build:ts": "rollup -c",
    "build:scss": "sass --no-source-map src/css/dojoless.scss dojoless.css",
    "watch:ts": "rollup -c -w",
    "watch:scss": "sass --watch src/css/dojoless.scss dojoless.css",
    "watch": "npm run watch:ts && npm run watch:scss",
    "build": "npm run build:ts && npm run build:scss",
    "jstests": "TS_NODE_PROJECT=src/tests/tsconfig.json mocha -r ts-node/register -r src/tests/setup.ts src/tests/**/*.spec.ts",
    "test": "APP_GAMEMODULE_PATH=~/git/bga-sharedcode/misc/ phpunit --testdox --colors=always",
    "tests": "npm run test -- modules/php/Tests"
  },
  "author": "Alena Laskavaia",
  "license": "EPL2.0",
  "devDependencies": {
    "@prettier/plugin-php": "^0.22",
    "@rollup/plugin-typescript": "^12",
    "@types/chai": "^4",
    "@types/jsdom": "^28",
    "@types/mocha": "^10",
    "@types/node": "^10",
    "@types/sinon": "^21",
    "chai": "^4",
    "jsdom": "^28",
    "mocha": "^11",
    "prettier": "^3",
    "rollup": "^4",
    "sass": "^1",
    "sinon": "^21",
    "ts-node": "^10",
    "tslib": "^2",
    "typescript": "^5"
  },
  "prettier": {
    "plugins": [
      "@prettier/plugin-php"
    ],
    "braceStyle": "1tbs",
    "printWidth": 140,
    "trailingComma": "none"
  }
}
