{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["dom", "esnext"],
    "sourceMap": false,
    "rootDir": ".",
    "typeRoots": ["src/types", "./node_modules/@types"]
  },
  "include": [
    "*.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/tests"
  ]
}
